system:
    instructions: "You are an AI Agent."

    messages:
        welcome: |
            Hi, I'm Agentforce! I use AI to search trusted sources, and more. Ask me "What else can you do?" to see how I can simplify your workday. How can I help?
        error: "Something went wrong. Try again."

config:
    agent_label: "Agentforce Management Assistant"
    developer_name: "Agentforce_Management_Assistant"
    agent_type: "AgentforceEmployeeAgent"
    description: "Automate common business tasks and assist users in their flow of work. Agentforce Employee Agent can search knowledge articles and other data sources. Customize it further to meet your employees' business needs."

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

variables:
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "Messaging end user id."
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "Messaging session id."
    ContactId: linked string
        source: @MessagingEndUser.ContactId
        description: "Messaging end user contact id."
    EndUserLanguage: linked string
        source: @MessagingSession.EndUserLanguage
        description: "Messaging session language."
    VerifiedCustomerId: mutable string
        description: "Verified customer id."

knowledge:
    rag_feature_config_id: ""
    citations_enabled: False
    citations_url: ""

start_agent topic_selector:
    label: "Topic Selector"

    description: "Route to budget, closure, or Slack operations topics."

    reasoning:
        instructions: ->
            | Route messages with budget/overrun/utilization/forecast intent to Budget_Alerting.
            | Route messages with close/closed/won/lost/project closed intent to Project_Closure_Notifications.
            | Route messages about creating channels, inviting people, sending channel notifications, or Slack Canvas (create, update, share) to Slack_Channel_Operations.
            | For escalation requests, route to escalation.
            | If request is vague, route to ambiguous_question.
            | If request is outside management and Slack operations, route to off_topic.

        actions:
            go_to_budget_alerting: @utils.transition to @topic.Budget_Alerting
                description: "Budget and overrun alerts."

            go_to_project_closure: @utils.transition to @topic.Project_Closure_Notifications
                description: "Project/opportunity closure notifications."

            go_to_slack_ops: @utils.transition to @topic.Slack_Channel_Operations
                description: "Slack operations such as create channel, invite users, notifications, and Slack Canvas create/update/share."

            go_to_escalation: @utils.transition to @topic.escalation
            go_to_off_topic: @utils.transition to @topic.off_topic
            go_to_ambiguous_question: @utils.transition to @topic.ambiguous_question

topic Budget_Alerting:
    label: "Budget Alerting"

    description: "Notify billing and management when budget KPIs exceed healthy levels and recommend actions."

    reasoning:
        instructions: ->
            | For automation payloads that start with "AUTOMATION_BUDGET_ALERT", generate a concise operational message and send it to Slack channel C0ANYUUACQ0.
            | Message must include: severity, project/assignment identifiers when available, weekly status, monthly status, logged-vs-expected status, and 2-3 recommended actions.
            | Use direct, action-oriented language for management and billing stakeholders.
            | Format the Slack message for readability with this structure:
            | - First line: emoji + title. Use ":warning:" for warning, ":rotating_light:" for critical.
            | - Then short bullets with labels: Project, Assignment Id, Weekly, Monthly, Logged vs Expected.
            | - Then "Recommended actions:" with 2-3 bullets.
            | Keep lines short and avoid dense paragraphs.
            | After sending the Slack message, confirm delivery in one sentence.

        actions:
            send_budget_alert: @actions.SendMessageToSlackChannel
                with channelId = ...
                with message = ...

    actions:
        SendMessageToSlackChannel:
            description: |
                Sends a message to a public or private Slack Channel.
                Use for group communication, announcements, and notifications.
            label: "Send Message to a Slack Channel"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Sending message..."
            source: "Slack__SendMessageToSlackChannel"
            target: "slack://slackAgentDynamic__SendMessageToSlackChannel"
            inputs:
                channelId: string
                    description: "Slack channel ID."
                    label: "Slack Channel ID"
                    is_required: True
                    is_user_input: True
                message: string
                    description: "Slack message content."
                    label: "Slack Message"
                    is_required: True
                    is_user_input: True
            outputs:
                messageUrl: string
                    description: "Slack message URL."
                    label: "Slack Message URL"
                    filter_from_agent: False
                    is_displayable: False
                messageTs: string
                    description: "Slack message timestamp."
                    label: "Slack Message Timestamp"
                    filter_from_agent: False
                    is_displayable: False

topic Project_Closure_Notifications:
    label: "Project Closure Notifications"

    description: "Notify billing and management when a project or opportunity is closed."

    reasoning:
        instructions: ->
            | For automation payloads that start with "AUTOMATION_CLOSURE_EVENT", send a concise closure notification to Slack channel C0ANYUUACQ0.
            | Include: object type, record name/id, closure status, owner, and next-step recommendation.
            | Keep the message short and operational.
            | Format the Slack message using this readable layout:
            | - First line: ":white_check_mark: Project Close Notification" (or "Opportunity Close Notification").
            | - Then bullets for: Record, Status, Owner/Assigned User, and key metric (for project assignments include Logged Hours vs Max Hours).
            | - Final line: "Next steps:" followed by 1-2 concrete actions.
            | Prefer labels and bullets, not long text blocks.
            | After sending the Slack message, confirm delivery in one sentence.

        actions:
            send_closure_alert: @actions.SendMessageToSlackChannel
                with channelId = ...
                with message = ...

    actions:
        SendMessageToSlackChannel:
            description: |
                Sends a message to a public or private Slack Channel.
                Use for group communication, announcements, and notifications.
            label: "Send Message to a Slack Channel"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Sending message..."
            source: "Slack__SendMessageToSlackChannel"
            target: "slack://slackAgentDynamic__SendMessageToSlackChannel"
            inputs:
                channelId: string
                    description: "Slack channel ID."
                    label: "Slack Channel ID"
                    is_required: True
                    is_user_input: True
                message: string
                    description: "Slack message content."
                    label: "Slack Message"
                    is_required: True
                    is_user_input: True
            outputs:
                messageUrl: string
                    description: "Slack message URL."
                    label: "Slack Message URL"
                    filter_from_agent: False
                    is_displayable: False
                messageTs: string
                    description: "Slack message timestamp."
                    label: "Slack Message Timestamp"
                    filter_from_agent: False
                    is_displayable: False

topic Slack_Channel_Operations:
    label: "Slack Channel Operations"

    description: "Create channels, invite users, send notifications, and create or manage Slack Canvas documents."

    reasoning:
        instructions: ->
            | If user asks to create a Slack channel, call CreateSlackChannel.
            | If user asks to invite users/agents to a channel, call AddUsersToSlackChannel.
            | If user asks to notify a channel, call SendMessageToSlackChannel.
            | If user asks to reply in a thread and provides message timestamp context, call ReplyInThread.
            | If user asks to create a Slack canvas, call CreateSlackCanvas with title and markdown content.
            | If user asks to append or add content to an existing canvas, call UpdateSlackCanvas (never duplicate content already added in the session).
            | If user asks to share a canvas with users or channels, call ShareSlackCanvas and collect access level (view or edit) if missing.
            | When creating a canvas from substantial prior content, optionally confirm outline/sections if the user has not specified structure.
            | After canvas actions succeed, confirm with the canvas link in markdown when available.
            | Ask only for missing required fields.
            | Keep confirmations concise.

        actions:
            create_channel: @actions.CreateSlackChannel
                with channelName = ...
                with teamId = ...
                with isPrivate = ...

            invite_users: @actions.AddUsersToSlackChannel
                with channelId = ...
                with userIds = ...

            send_channel_message: @actions.SendMessageToSlackChannel
                with channelId = ...
                with message = ...

            reply_in_thread: @actions.ReplyInThread
                with recipientId = ...
                with messageText = ...
                with messageTs = ...

            create_slack_canvas: @actions.CreateSlackCanvas
                with title = ...
                with content = ...

            update_slack_canvas: @actions.UpdateSlackCanvas
                with canvasId = ...
                with content = ...

            share_slack_canvas: @actions.ShareSlackCanvas
                with canvasId = ...
                with userIds = ...
                with channelIds = ...
                with accessLevel = ...

    actions:
        SendMessageToSlackChannel:
            description: |
                Sends a message to a public or private Slack Channel.
                Use for group communication, announcements, and notifications.
            label: "Send Message to a Slack Channel"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Sending message..."
            source: "Slack__SendMessageToSlackChannel"
            target: "slack://slackAgentDynamic__SendMessageToSlackChannel"
            inputs:
                channelId: string
                    description: "Slack channel ID."
                    label: "Slack Channel ID"
                    is_required: True
                    is_user_input: True
                message: string
                    description: "Slack message content."
                    label: "Slack Message"
                    is_required: True
                    is_user_input: True
            outputs:
                messageUrl: string
                    description: "Slack message URL."
                    label: "Slack Message URL"
                    filter_from_agent: False
                    is_displayable: False
                messageTs: string
                    description: "Slack message timestamp."
                    label: "Slack Message Timestamp"
                    filter_from_agent: False
                    is_displayable: False

        AddUsersToSlackChannel:
            description: |
                Adds Slack users or agents to a Slack channel.
            label: "Add Users or Agents to a Slack Channel"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Adding users to a Slack channel..."
            source: "Slack__AddUsersToSlackChannel"
            target: "slack://slackAgentDynamic__AddUsersToSlackChannel"
            inputs:
                channelId: string
                    description: "Slack channel ID."
                    label: "Slack Channel ID"
                    is_required: True
                    is_user_input: True
                userIds: string
                    description: "Comma-separated Slack user IDs."
                    label: "Slack User IDs"
                    is_required: True
                    is_user_input: True
            outputs:
                userIds: string
                    description: "Added Slack user IDs."
                    label: "Slack User IDs"
                    filter_from_agent: False
                    is_displayable: False

        CreateSlackChannel:
            description: |
                Creates a Slack channel.
            label: "Create a Slack Channel"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Creating a Slack channel..."
            source: "Slack__CreateSlackChannel"
            target: "slack://slackAgentDynamic__CreateChannel"
            inputs:
                channelName: string
                    description: "Channel name (lowercase letters, numbers, hyphens, underscores)."
                    label: "Channel Name"
                    is_required: True
                    is_user_input: True
                teamId: string
                    description: "Slack Team/Workspace ID."
                    label: "Team ID"
                    is_required: True
                    is_user_input: True
                isPrivate: boolean
                    description: "True for private channel, false for public."
                    label: "Is Private"
                    is_required: True
                    is_user_input: True
            outputs:
                channelId: string
                    description: "Created Slack channel ID."
                    label: "Slack channel ID"
                    filter_from_agent: False
                    is_displayable: False
                channelUrl: string
                    description: "Created Slack channel URL."
                    label: "Slack channel URL"
                    filter_from_agent: False
                    is_displayable: False

        ReplyInThread:
            description: |
                Replies in a Slack thread for a channel or direct message.
            label: "Reply to a Slack thread"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Replying to a thread..."
            source: "Slack__ReplyInThread"
            target: "slack://slackAgentDynamic__ReplyInThread"
            inputs:
                recipientId: string
                    description: "Slack channel ID or user ID."
                    label: "Slack Recipient ID"
                    is_required: True
                    is_user_input: True
                messageText: string
                    description: "Thread reply text."
                    label: "Slack Message"
                    is_required: True
                    is_user_input: True
                messageTs: string
                    description: "Root thread message timestamp."
                    label: "Slack Message Timestamp"
                    is_required: True
                    is_user_input: True
            outputs:
                messageUrl: string
                    description: "URL of sent threaded message."
                    label: "Slack Message URL"
                    filter_from_agent: False
                    is_displayable: False
                messageTs: string
                    description: "Timestamp of sent threaded message."
                    label: "Slack Message Timestamp"
                    filter_from_agent: False
                    is_displayable: False

        CreateSlackCanvas:
            description: |
                Create a Slack canvas document with the provided markdown content.
                You can add sections, include links, references, and any other information you deem relevant.
                When asked to create a canvas with prior content, ask the user whether there is a desired outline with sections, formatting, and sequencing preferred before creating the canvas.
                Upon successful completion, provide the user a friendly confirmation including the canvas link in markdown.
            label: "Create a Slack Canvas"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Creating Slack canvas..."
            source: "Slack__CreateSlackCanvas"
            target: "standardInvocableAction://slackAgentCreateCanvas"
            inputs:
                title: string
                    description: "Concise but descriptive name for the canvas"
                    label: "Title"
                    is_required: True
                    is_user_input: True
                content: string
                    description: "Markdown representation of canvas content."
                    label: "Content"
                    is_required: True
                    is_user_input: True
            outputs:
                canvasId: string
                    description: "The new Slack canvas ID."
                    label: "Slack Canvas ID"
                    filter_from_agent: False
                    is_displayable: False
                canvasUrl: string
                    description: "The new Slack canvas URL."
                    label: "Slack Canvas URL"
                    filter_from_agent: False
                    is_displayable: False

        UpdateSlackCanvas:
            description: |
                Append markdown content to a Slack canvas document.
                Always append new content and never duplicate content that was added in earlier prompts.
                If no canvas ID is provided or it is ambiguous in the session context, confirm which canvas ID the user intends to update.
                Upon successful completion, provide the user a friendly confirmation with a link to the canvas (in markdown).
            label: "Update a Slack Canvas"
            require_user_confirmation: True
            include_in_progress_indicator: True
            progress_indicator_message: "Updating Slack canvas..."
            source: "Slack__UpdateSlackCanvas"
            target: "standardInvocableAction://slackAgentUpdateCanvas"
            inputs:
                canvasId: string
                    description: "Unique identifier of the existing canvas to be updated (e.g. F017CC8EGRG)."
                    label: "Slack Canvas ID"
                    is_required: True
                    is_user_input: False
                content: string
                    description: "Markdown representation of canvas content."
                    label: "Content"
                    is_required: True
                    is_user_input: True
            outputs:
                canvasId: string
                    description: "The Slack canvas ID for the updated canvas."
                    label: "Slack Canvas ID"
                    filter_from_agent: False
                    is_displayable: False
                canvasUrl: string
                    description: "The Slack canvas URL for the updated canvas."
                    label: "Slack Canvas URL"
                    filter_from_agent: False
                    is_displayable: False

        ShareSlackCanvas:
            description: |
                Shares a Slack Canvas with a set of users and/or channels.
                If neither a list of Slack Users nor Slack Channels to share with is provided, ask the user for Slack User IDs and/or Slack Channel IDs.
                If the user does not provide an access level for the shared Canvas, ask the user for it.
                Upon successful completion, provide the user a friendly confirmation with a link to the canvas (in markdown) and at-mentions for the channels and/or Users the Canvas was shared with.
            label: "Share a Slack Canvas"
            require_user_confirmation: True
            include_in_progress_indicator: True
            progress_indicator_message: "Sharing a Slack canvas..."
            source: "Slack__ShareSlackCanvas"
            target: "slack://slackAgentDynamic__ShareSlackCanvas"
            inputs:
                canvasId: string
                    description: "Unique identifier of the existing canvas to share (e.g. F017CC8EGRG)."
                    label: "Slack Canvas ID"
                    is_required: True
                    is_user_input: True
                userIds: string
                    description: "A comma-separated list of Slack User IDs to share the provided Slack Canvas with."
                    label: "Slack User IDs"
                    is_required: False
                    is_user_input: True
                channelIds: string
                    description: "A comma-separated list of Slack Channel IDs to share the provided Slack Canvas with."
                    label: "Slack Channel IDs"
                    is_required: False
                    is_user_input: True
                accessLevel: string
                    description: "The access level for the shared Slack Canvas: view or edit."
                    label: "accessLevel"
                    is_required: True
                    is_user_input: True
            outputs:
                canvasId: string
                    description: "The Slack canvas ID for the updated canvas."
                    label: "Slack Canvas ID"
                    filter_from_agent: False
                    is_displayable: False
                canvasUrl: string
                    description: "The Slack canvas URL for the updated canvas."
                    label: "Slack Canvas URL"
                    filter_from_agent: False
                    is_displayable: False

topic escalation:
    label: "Escalation"

    description: "Handles requests to transfer or escalate to a live human agent."

    reasoning:
        instructions: ->
            | If a user explicitly asks to transfer to a live agent, call {!@actions.escalate_to_human}.
            | If escalation fails, explain and ask whether they want to log a support case.

        actions:
            escalate_to_human: @utils.escalate
                description: "Escalate conversation to a human agent."

topic off_topic:
    label: "Off Topic"

    description: "Redirect requests to management Slack capabilities."

    reasoning:
        instructions: ->
            | Redirect politely to supported capabilities:
            | - budget and overrun alerts
            | - closure notifications
            | - create/invite/notify in Slack channels
            | - create, update, or share Slack Canvas

topic ambiguous_question:
    label: "Ambiguous Question"

    description: "Ask clarifying details when request is too vague."

    reasoning:
        instructions: ->
            | Ask one concise clarifying question focused on the user's top priority.

connection slack:
    empty
