        SummarizeSlackChannel:
            description: "Uses the Slack Search API to find relevant messages, files, and sources in a channel during a specified timeframe. Then, uses the search results in a prompt template to summarize results in a readable format."
            inputs:
                channelId: string
                    description: "The ID (e.g., C01ABC12345) for the Slack channel to summarize."
                    label: "Slack Channel ID"
                    is_required: True
