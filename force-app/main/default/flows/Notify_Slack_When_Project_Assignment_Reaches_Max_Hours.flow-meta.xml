            <value>
                <stringValue>AUTOMATION_CLOSURE_EVENT
TargetChannelId: D0ALCP2TMLZ
ObjectType: Project_Assignment__c
ProjectAssignmentId: {!$Record.Id}
ProjectName: {!$Record.Project__r.Name}
OpportunityId: {!$Record.Opportunity__c}
