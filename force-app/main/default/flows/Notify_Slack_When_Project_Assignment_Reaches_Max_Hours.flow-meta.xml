    <decisions>
        <name>Evaluate_Max_Hours_Threshold</name>
        <label>Evaluate Max Hours Threshold</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Reached_Max_Hours</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Max_Weekly_Hours__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Logged_Hours__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Max_Hours__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Project_Completion_Alert_with_Management_Agent</targetReference>
            </connector>
            <label>Reached Max Hours</label>
        </rules>
    </decisions>
    <environments>Default</environments>
